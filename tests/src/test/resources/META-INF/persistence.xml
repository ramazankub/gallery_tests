<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <!--  Здесь задаются настройки для доступа к базе rococo-artist. Чтобы ходить в другую базу,   -->
    <!--  нужно скопировать блок persistence-unit и заменить путь до Entity и путь до базы -->
    <persistence-unit name="rococo-artist" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Путь до Enity -->
        <class>ru.gallery.data.entity.ArtistEntity</class>

        <properties>
            <!-- Настройки JDBC -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <!-- Путь до базы rococo-artist -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://ru.tuna.am:37038/rococo-artist"/>
            <!-- Если хочешь глазами посмотреть на базу, например через DBeaver, можешь взять путь выше и логин/пароль отсюда -->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="secret"/>

            <!-- Настройки Hibernate -->
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.jdbc.time_zone" value="UTC"/>
        </properties>
    </persistence-unit>

